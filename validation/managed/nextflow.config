plugins {
    id 'nf-metro@0.1.0'
}

process.executor = 'local'

executor {
    cpus      = 2
    queueSize = 4
}

// Managed mode: the plugin spawns/stops the server itself (nf-metro on PATH).
// Omitting `port` lets it pick a free port; set `open = true` to pop a browser.
metro {
    map = "${projectDir}/../pipeline.mmd"
}
